<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeus.mapper.CodeMapper">
	<!-- 그룹코드 목록 조회 -->
	<select id="getCodeGruopList"
		resultType="com.zeus.common.domain.CodeLabelValue">
		SELECT GROUP_CODE AS VALUE,
		GROUP_NAME AS LABEL
		FROM
		CODE_GROUP
		WHERE USE_YN = 'Y'
		ORDER BY GROUP_NAME
	</select>
</mapper>
